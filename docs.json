                    ]
                  },
                  {
                    "group": "VirtualMachine",
                    "pages": [
                      "GET /v1/compute/apis/vm.mountthor.dev/v1alpha1/namespaces/{namespace}/virtualmachines",
                      "POST /v1/compute/apis/vm.mountthor.dev/v1alpha1/namespaces/{namespace}/virtualmachines",
                      "GET /v1/compute/apis/vm.mountthor.dev/v1alpha1/namespaces/{namespace}/virtualmachines/{name}",
                      "DELETE /v1/compute/apis/vm.mountthor.dev/v1alpha1/namespaces/{namespace}/virtualmachines/{name}"
                    ]
                  },
                  {
                    "group": "VirtualMachineImage",
                    "pages": [
                      "GET /v1/compute/apis/vm.mountthor.dev/v1alpha1/namespaces/{namespace}/virtualmachineimages",
                      "GET /v1/compute/apis/vm.mountthor.dev/v1alpha1/namespaces/{namespace}/virtualmachineimages/{name}"
                    ]
                  },
                  {
                    "group": "VirtualMachineImageOperation",
                    "pages": [
                      "GET /v1/compute/apis/vm.mountthor.dev/v1alpha1/namespaces/{namespace}/virtualmachineimageoperations",
                      "POST /v1/compute/apis/vm.mountthor.dev/v1alpha1/namespaces/{namespace}/virtualmachineimageoperations",
                      "GET /v1/compute/apis/vm.mountthor.dev/v1alpha1/namespaces/{namespace}/virtualmachineimageoperations/{name}",
                      "DELETE /v1/compute/apis/vm.mountthor.dev/v1alpha1/namespaces/{namespace}/virtualmachineimageoperations/{name}"
                    ]
                  },
                  {
                    "group": "VirtualMachineOperation",
                    "pages": [
                      "GET /v1/compute/apis/vm.mountthor.dev/v1alpha1/namespaces/{namespace}/virtualmachineoperations",
                      "POST /v1/compute/apis/vm.mountthor.dev/v1alpha1/namespaces/{namespace}/virtualmachineoperations",
                      "GET /v1/compute/apis/vm.mountthor.dev/v1alpha1/namespaces/{namespace}/virtualmachineoperations/{name}",
                      "DELETE /v1/compute/apis/vm.mountthor.dev/v1alpha1/namespaces/{namespace}/virtualmachineoperations/{name}"
                    ]
