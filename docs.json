{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Mount Thor",
  "description": "Customer documentation for Mount Thor: dedicated Apple Silicon, no virtualization layer between you and the metal.",
  "colors": {
    "primary": "#C9A84C",
    "light": "#D4B45A",
    "dark": "#C9A84C"
  },
  "appearance": {
    "default": "dark"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://docs.mountthor.com"
  },
  "fonts": {
    "heading": {
      "family": "Cormorant Garamond",
      "weight": 500,
      "source": "https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600&display=swap",
      "format": "woff2"
    },
    "body": {
      "family": "Barlow",
      "weight": 400,
      "source": "https://fonts.googleapis.com/css2?family=Barlow:wght@300;400;500;600&display=swap",
      "format": "woff2"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Concepts",
            "pages": [
              "concepts/auth",
              "concepts/supported-apis"
            ]
          },
          {
            "group": "Compute",
            "pages": [
              "compute/bare-metal",
              "compute/virtual-machines"
            ]
          },
          {
            "group": "Troubleshooting",
            "pages": [
              "troubleshooting/common-failures"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Admin API",
            "openapi": {
              "source": "https://api.mountthor.com/openapi.json",
              "directory": "api-reference/admin"
            }
          },
          {
            "group": "Compute API",
            "openapi": {
              "source": "/api-reference/customer-compute-crds.v1.openapi.json",
              "directory": "api-reference/compute"
            }
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Supported APIs",
        "href": "https://docs.mountthor.com/concepts/supported-apis"
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Mount-Thor"
    }
  }
}
