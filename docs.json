{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Mount Thor",
  "description": "Customer documentation for Mount Thor: Apple hardware at datacenter scale for bare-metal leases and macOS virtual machines.",
  "colors": {
    "primary": "#C9A84C",
    "light": "#D4B45A",
    "dark": "#C9A84C"
  },
  "appearance": {
    "default": "dark"
  },
  "favicon": "/favicon.svg",
  "redirects": [
    {
      "source": "/",
      "destination": "/quickstart",
      "permanent": false
    },
    {
      "source": "/concepts/get-access",
      "destination": "/quickstart",
      "permanent": false
    }
  ],
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://docs.mountthor.com"
  },
  "fonts": {
    "heading": {
      "family": "Cormorant Garamond",
      "weight": 500,
      "source": "https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600&display=swap",
      "format": "woff2"
    },
    "body": {
      "family": "Barlow",
      "weight": 400,
      "source": "https://fonts.googleapis.com/css2?family=Barlow:wght@300;400;500;600&display=swap",
      "format": "woff2"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "pages": [
          "quickstart",
          "compute/bare-metal",
          "compute/virtual-machines",
          {
            "group": "API Reference",
            "openapi": {
              "source": "/api-reference/mount-thor-local.openapi.json",
              "directory": "api-reference"
            },
            "pages": [
              {
                "group": "Account",
                "pages": [
                  "GET /v1/admin/account",
                  "PATCH /v1/admin/account"
                ]
              },
              {
                "group": "API Keys",
                "pages": [
                  "GET /v1/admin/keys",
                  "POST /v1/admin/keys",
                  "DELETE /v1/admin/keys/{id}"
                ]
              },
              {
                "group": "Sessions",
                "pages": [
                  "GET /v1/admin/sessions",
                  "POST /v1/admin/sessions",
                  "DELETE /v1/admin/sessions/{id}"
                ]
              },
              {
                "group": "Fleet",
