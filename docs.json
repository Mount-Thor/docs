{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Mount Thor",
  "description": "Customer documentation for Mount Thor: Apple hardware at datacenter scale for bare-metal machines and macOS virtual machines.",
  "colors": {
    "primary": "#C9A84C",
    "light": "#D4B45A",
    "dark": "#C9A84C"
  },
  "appearance": {
    "default": "dark"
  },
  "favicon": "/favicon.svg",
  "redirects": [
    {
      "source": "/",
      "destination": "/quickstart",
      "permanent": false
    },
    {
      "source": "/concepts/get-access",
      "destination": "/quickstart",
      "permanent": false
    }
  ],
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://docs.mountthor.com"
  },
  "fonts": {
    "heading": {
      "family": "Cormorant Garamond",
      "weight": 500,
      "source": "https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600&display=swap",
      "format": "woff2"
    },
    "body": {
      "family": "Barlow",
      "weight": 400,
      "source": "https://fonts.googleapis.com/css2?family=Barlow:wght@300;400;500;600&display=swap",
      "format": "woff2"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "pages": [
          "quickstart",
          "compute/bare-metal",
          "compute/virtual-machines",
          {
            "group": "API Reference",
            "openapi": {
              "source": "/api-reference/customer-api.v1.openapi.json",
              "directory": "api-reference"
            },
            "pages": [
              {
                "group": "Accounts",
                "pages": [
                  "GET /v1/admin/account",
                  "PATCH /v1/admin/account",
                  "POST /v1/admin/registrations"
                ]
              },
              {
                "group": "API Keys",
                "pages": [
                  "GET /v1/admin/keys",
                  "POST /v1/admin/keys",
                  "DELETE /v1/admin/keys/{id}"
                ]
              },
              {
                "group": "Sessions",
                "pages": [
                  "GET /v1/admin/sessions",
                  "POST /v1/admin/sessions",
                  "POST /v1/admin/sessions/authorize",
                  "DELETE /v1/admin/sessions/{id}"
                ]
              },
              {
                "group": "Access",
                "pages": [
                  "POST /v1/admin/access/grants/desktop",
                  "POST /v1/admin/access/grants/ssh",
                  "POST /v1/admin/access/grants/tunnel",
                  "DELETE /v1/admin/access/grants/{grant_id}"
                ]
              },
              {
                "group": "Fleet",
                "pages": [
                  "GET /v1/admin/fleet",
                  "GET /v1/admin/fleet/capacity",
                  "GET /v1/admin/machine-availability",
                  "GET /v1/admin/fleet/summary",
                  "GET /v1/admin/fleet/usage"
                ]
              },
              {
                "group": "Bare Metal",
                "pages": [
                  "POST /v1/admin/bare-metal-machines",
                  "GET /v1/admin/operations"
                ]
              },
              {
                "group": "Customer Users",
                "pages": [
                  "GET /v1/admin/customer-users",
                  "POST /v1/admin/customer-users/invite"
                ]
              },
              {
                "group": "Billing",
                "pages": [
                  "GET /v1/admin/billing/usage",
                  "GET /v1/admin/billing/costs",
                  "GET /v1/admin/billing/invoices",
                  "GET /v1/admin/billing/invoices/{invoice_id}",
                  "GET /v1/admin/billing/price-catalog"
                ]
              },
              {
                "group": "Compute",
                "pages": [
                  {
                    "group": "Bare Metal Machines",
                    "pages": [
                      "GET /v1/compute/apis/compute.mountthor.com/v1alpha1/namespaces/{namespace}/baremetalmachines",
                      "POST /v1/compute/apis/compute.mountthor.com/v1alpha1/namespaces/{namespace}/baremetalmachines",
                      "GET /v1/compute/apis/compute.mountthor.com/v1alpha1/namespaces/{namespace}/baremetalmachines/{name}",
                      "DELETE /v1/compute/apis/compute.mountthor.com/v1alpha1/namespaces/{namespace}/baremetalmachines/{name}"
                    ]
                  },
                  {
                    "group": "Virtual Machines",
                    "pages": [
                      "GET /v1/compute/apis/compute.mountthor.com/v1alpha1/namespaces/{namespace}/virtualmachines",
                      "POST /v1/compute/apis/compute.mountthor.com/v1alpha1/namespaces/{namespace}/virtualmachines",
                      "GET /v1/compute/apis/compute.mountthor.com/v1alpha1/namespaces/{namespace}/virtualmachines/{name}",
                      "DELETE /v1/compute/apis/compute.mountthor.com/v1alpha1/namespaces/{namespace}/virtualmachines/{name}"
                    ]
                  },
                  {
                    "group": "Images",
                    "pages": [
                      "GET /v1/compute/apis/compute.mountthor.com/v1alpha1/namespaces/{namespace}/images",
                      "GET /v1/compute/apis/compute.mountthor.com/v1alpha1/namespaces/{namespace}/images/{name}"
                    ]
                  },
                  {
                    "group": "Machine Classes",
                    "pages": [
                      "GET /v1/compute/apis/compute.mountthor.com/v1alpha1/namespaces/{namespace}/machineclasses",
                      "GET /v1/compute/apis/compute.mountthor.com/v1alpha1/namespaces/{namespace}/machineclasses/{name}"
                    ]
                  },
                  {
                    "group": "Fleet Policies",
                    "pages": [
                      "GET /v1/compute/apis/compute.mountthor.com/v1alpha1/namespaces/{namespace}/fleetpolicies",
                      "GET /v1/compute/apis/compute.mountthor.com/v1alpha1/namespaces/{namespace}/fleetpolicies/{name}"
                    ]
                  }
                ]
              },
              {
                "group": "Identity",
                "pages": [
                  "GET /v1/admin/identity",
                  "POST /v1/admin/identity-setup-link",
                  "GET /v1/admin/identity/providers",
                  "POST /v1/admin/identity/providers",
                  "PATCH /v1/admin/identity/providers/{id}"
                ]
              },
              {
                "group": "Principals",
                "pages": [
                  "GET /v1/admin/identity/principals",
                  "POST /v1/admin/identity/principals",
                  "PATCH /v1/admin/identity/principals/{id}"
                ]
              },
              {
                "group": "Registries",
                "pages": [
                  "GET /v1/admin/registries",
                  "POST /v1/admin/registries",
                  "GET /v1/admin/registries/{id}",
                  "PATCH /v1/admin/registries/{id}",
                  "DELETE /v1/admin/registries/{id}"
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
